# Template file for 'nano-syntax-highlighting'
pkgname=nano-syntax-highlighting
version=2026.03.14
revision=1
depends="nano"
short_desc="Nano editor syntax highlighting enhancements"
maintainer="masn <masn@togeter.net>"
license="GPL-3.0-or-later"
homepage="https://github.com/galenguyer/nano-syntax-highlighting"
distfiles="https://github.com/galenguyer/nano-syntax-highlighting/archive/refs/tags/${version}.tar.gz"
checksum=9c514fbc26e1a8d126ba931a77c03ed2d779554cb0f80ec0175f4d76d01c26c3

do_install() {
	find *.nanorc -type f | sed "s@^@include /usr/share/${pkgname}/@" > nanorc.sample
	vmkdir usr/share/${pkgname}/
	vcopy *.nanorc usr/share/${pkgname}/
	vcopy nanorc.sample usr/share/${pkgname}/
	vlicense license
}
